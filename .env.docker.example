# Publicacion
APP_PORT=8014
VITE_API_URL=/api/v1

# Django
DJANGO_SECRET_KEY=change-this-in-vm
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.15.215
CORS_ALLOWED_ORIGINS=http://192.168.15.215:8014
CSRF_TRUSTED_ORIGINS=http://192.168.15.215:8014

# Base de datos
POSTGRES_DB=credito_digital
POSTGRES_USER=credito_digital
POSTGRES_PASSWORD=change-this-postgres-password

# Runtime
DRF_BURST_RATE=15/min
DRF_SUSTAINED_RATE=100/day
EXTERNAL_API_TIMEOUT=15
CREDIT_PIPELINE_ASYNC=0
CREDIT_USE_MOCK_SERVICES=0

# Oracle / LINIX
# Si va activo, XCORE_CONSUMO_ORACLE_ENABLED debe ser 1.
XCORE_CONSUMO_ORACLE_ENABLED=0
ORACLE_DSN=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=
ORACLE_USER=
ORACLE_PASSWORD=

# PRESELECTA / Okta
# SERVICE_URL es el endpoint real usado por el cliente.
# PRESELECTA_API_URL puede usarse como alias si prefieres no repetir SERVICE_URL.
PRESELECTA_API_URL=
SERVICE_URL=
OKTA_TOKEN_URL=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_USERNAME=
OKTA_PASSWORD=
OKTA_SCOPE=
OKTA_GRANT_TYPE=password
PRESELECTA_AUTH_STYLE=access_token
PRESELECTA_VERIFY_SSL=1
PRESELECTA_INQUIRY_ID=892000373
PRESELECTA_INQUIRY_CLIENT_TYPE=2
PRESELECTA_INQUIRY_USER_TYPE=2

# Historial de pago / Datacredito SOAP
# Con CREDIT_USE_MOCK_SERVICES=0 estos valores deben estar completos y validos.
HISTORIAL_PAGO_SOAP_URL=
DATACREDITO_WSDL_URL=
DATACREDITO_OKTA_USER=
DATACREDITO_OKTA_PASSWORD=
DATACREDITO_SOAP_USER=
DATACREDITO_SOAP_PASSWORD=
DATACREDITO_PRODUCT_ID=64
DATACREDITO_INFO_ACCOUNT_TYPE=1
DATACREDITO_SOAP_CERT=/app/certs/client_cert.pem
DATACREDITO_SOAP_KEY=/app/certs/client_key.pem
DATACREDITO_SOAP_FULLCHAIN=/app/certs/client_fullchain.pem
DATACREDITO_SOAP_ADDRESS=
DATACREDITO_SOAP_CA_BUNDLE=
DATACREDITO_SERVER_IP=
DATACREDITO_SOAP_USE_WSSE=1
DATACREDITO_SOAP_USE_SIGNATURE=1
DATACREDITO_SOAP_SIGNATURE_MODE=binary
DATACREDITO_SOAP_PASSWORD_DIGEST=0
DATACREDITO_SOAP_LOG_XML=0
DATACREDITO_SOAP_TLS_VERIFY=1
DATACREDITO_SOAP_MINIMAL_FIELDS=1
DATACREDITO_SOAP_TTL_SECONDS=300
DATACREDITO_SOAP_TIME_SKEW_SECONDS=120

# XCORE legado
XCORE_API_URL=
# real = usa la cedula digitada. test = fuerza una identidad demo hacia PRESELECTA/HC2.
XCORE_PROVIDER_MODE=real
# Alias compatible: 1 tambien activa modo test.
XCORE_USE_PROVIDER_TEST_IDENTITIES=0
# Valores soportados: ORTIZ, PALACIOS
XCORE_PROVIDER_TEST_CASE=PALACIOS

# OTP / Twilio / Email
# OTP_AES_KEY_B64 es obligatoria para cifrado OTP y debe decodificar a 32 bytes.
OTP_PROVIDER_MODE=real
OTP_AES_KEY_B64=
OTP_EMAIL_CONSENT_URL=
OTP_EMAIL_LOGO_URL=
OTP_EMAIL_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=30
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
TWILIO_VERIFY_CHANNEL=sms
TWILIO_VERIFY_TEMPLATE_SID=
TWILIO_VERIFY_TTL_SECONDS=600
TWILIO_VERIFY_RESEND_MAX=3
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=
