# =========================
# Django / entorno base
# =========================
# Clave secreta de Django. Cambiar en cualquier ambiente distinto a local.
DJANGO_SECRET_KEY=change-me
# 1 = modo desarrollo. 0 = modo produccion.
DJANGO_DEBUG=1
# Hosts permitidos para Django.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =========================
# Base de datos PostgreSQL
# =========================
# Si POSTGRES_DB queda vacio, Django cae a SQLite. Para este proyecto debe ir con PostgreSQL.
POSTGRES_DB=credito_digital
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =========================
# Sesion, CORS y CSRF
# =========================
# Origenes permitidos del frontend React.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Origenes confiables para CSRF con sesion Django.
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================
# Throttling API
# =========================
# Rate limits de DRF para proteger endpoints.
DRF_BURST_RATE=15/min
DRF_SUSTAINED_RATE=100/day

# =========================
# Modo de ejecucion del pipeline
# =========================
# 1 = preparado para async/Celery. 0 = sincronico.
CREDIT_PIPELINE_ASYNC=0
# 1 = usar mocks en integraciones externas. 0 = usar servicios reales.
CREDIT_USE_MOCK_SERVICES=1
# Timeout general para integraciones externas en segundos.
EXTERNAL_API_TIMEOUT=15

# =========================
# Oracle / LINIX
# =========================
# Enciende la consulta real de SP_CREDITODIGITAL, SP_CONSULTACAPA y SP_CONSULTAFAMILIAR.
XCORE_CONSUMO_ORACLE_ENABLED=0
# Puedes usar ORACLE_DSN o el trio ORACLE_HOST/ORACLE_PORT/ORACLE_SERVICE_NAME.
ORACLE_DSN=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=
ORACLE_USER=
ORACLE_PASSWORD=

# =========================
# PRESELECTA / OKTA
# =========================
# URL del endpoint de negocio de PRESELECTA.
# Si SERVICE_URL queda vacio, backend reutiliza PRESELECTA_API_URL.
PRESELECTA_API_URL=https://api.preselecta.local/score
# Alias operativo del cliente PRESELECTA. Puedes dejarlo vacio si ya llenaste PRESELECTA_API_URL.
SERVICE_URL=
# URL de token de OKTA para autenticar contra PRESELECTA.
OKTA_TOKEN_URL=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
# Identificador operativo que el proveedor valida como nitUsuario.
# No reutiliza el client_id de Okta; por defecto se recomienda 892000373.
PRESELECTA_INQUIRY_ID=892000373
PRESELECTA_INQUIRY_CLIENT_TYPE=2
PRESELECTA_INQUIRY_USER_TYPE=2
# Solo aplica si OKTA_GRANT_TYPE=password.
OKTA_USERNAME=
OKTA_PASSWORD=
OKTA_SCOPE=
# password o client_credentials, segun el contrato real.
OKTA_GRANT_TYPE=password
# access_token o bearer, segun como PRESELECTA espere el token.
PRESELECTA_AUTH_STYLE=access_token
# 1 = verifica SSL. 0 = solo para entornos controlados.
PRESELECTA_VERIFY_SSL=1

# =========================
# Datacredito / Historial SOAP
# =========================
# URL general historica; el cliente SOAP resuelve el endpoint real desde el WSDL si aplica.
HISTORIAL_PAGO_SOAP_URL=https://soap.historial.local
DATACREDITO_WSDL_URL=
DATACREDITO_OKTA_USER=
DATACREDITO_OKTA_PASSWORD=
DATACREDITO_SOAP_USER=
DATACREDITO_SOAP_PASSWORD=
DATACREDITO_PRODUCT_ID=64
DATACREDITO_INFO_ACCOUNT_TYPE=1
# Rutas relativas al backend/ o absolutas para certificados SOAP.
DATACREDITO_SOAP_CERT=certs/client_cert.pem
DATACREDITO_SOAP_KEY=certs/client_key.pem
DATACREDITO_SOAP_FULLCHAIN=certs/client_fullchain.pem
DATACREDITO_SERVER_IP=
DATACREDITO_SOAP_USE_WSSE=1
DATACREDITO_SOAP_USE_SIGNATURE=1
DATACREDITO_SOAP_SIGNATURE_MODE=binary
DATACREDITO_SOAP_PASSWORD_DIGEST=0
# 1 = guarda XML SOAP en logs de desarrollo.
DATACREDITO_SOAP_LOG_XML=1
DATACREDITO_SOAP_TLS_VERIFY=1
DATACREDITO_SOAP_MINIMAL_FIELDS=1

# =========================
# Motor XCORE externo
# =========================
# Endpoint del motor externo si se deja de usar mock/local.
XCORE_API_URL=https://api.xcore.local/evaluate

# =========================
# Casos de prueba proveedor
# =========================
# 1 = fuerza PRESELECTA e historial a usar identidades quemadas del proveedor durante pruebas de integracion.
# Cuando este activo, ambas consultas reutilizan la misma cedula y apellido del caso definido abajo.
XCORE_USE_PROVIDER_TEST_IDENTITIES=0
# Valores soportados hoy: VARGAS, GOMEZ
XCORE_PROVIDER_TEST_CASE=VARGAS

# =========================
# OTP real por SMS y Email
# =========================
# Modo OTP: test = controlado/local, real = Twilio Verify para SMS y SMTP para EMAIL.
OTP_PROVIDER_MODE=test
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
TWILIO_VERIFY_CHANNEL=sms
TWILIO_VERIFY_TEMPLATE_SID=
TWILIO_VERIFY_TTL_SECONDS=600
TWILIO_VERIFY_RESEND_MAX=3
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=
OTP_AES_KEY_B64=
OTP_EMAIL_CONSENT_URL=
OTP_EMAIL_LOGO_URL=
OTP_EMAIL_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=30

